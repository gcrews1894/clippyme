# ──────────────────────────────────────────────────────────────
# ClippyMe — environment variables
# Copy to `.env` and fill in the values you care about.
# Most keys (Gemini, Deepgram, HF, cookies, Zernio) can also be
# configured from the dashboard Settings tab at runtime.
# ──────────────────────────────────────────────────────────────

# ── Gemini (required) ─────────────────────────────────────────
# Gemini API Key — get one at https://aistudio.google.com/apikey
GEMINI_API_KEY=

# Gemini model used for viral moment detection (default: gemini-3.5-flash)
GEMINI_MODEL=gemini-3.5-flash

# Retry behaviour when Gemini returns malformed JSON
# GEMINI_MAX_RETRIES=1
# GEMINI_RETRY_MODEL=gemini-2.5-pro

# ── Transcription ─────────────────────────────────────────────
# Provider used to transcribe the video audio track.
#   deepgram   — cloud Nova-3 (default, fastest, multilingual)
#   elevenlabs — cloud Scribe (audio-event tags as a viral signal)
#   whisper    — local Faster-Whisper (no API key, slower)
# TRANSCRIPTION_PROVIDER=deepgram

# Strip to an audio-only FLAC before transcribing (DEFAULT on) — much smaller
# Deepgram upload / no full-video decode, zero accuracy cost. Set false to send
# the original video file.
# CLIPPYME_TRANSCRIBE_AUDIO_ONLY=true

# Deepgram API Key — required when TRANSCRIPTION_PROVIDER=deepgram
# Get one at https://console.deepgram.com
DEEPGRAM_API_KEY=

# Deepgram tuning (all optional — defaults shown)
# DEEPGRAM_MODEL=nova-3
# DEEPGRAM_LANGUAGE=multi         # or 'it', 'en', 'es' … single-lang mode
# DEEPGRAM_DIARIZE=true           # speaker diarization (free on Nova-3)
# DEEPGRAM_KEYTERMS=              # comma-separated brand/jargon terms (Nova-3 only)
# DEEPGRAM_HTTP_TIMEOUT=600
# DEEPGRAM_MAX_RETRIES=3
# DEEPGRAM_MAX_FILE_MB=1900

# ElevenLabs Scribe — third transcription provider
# (TRANSCRIPTION_PROVIDER=elevenlabs). Adds audio-event tags
# ((laughter)/(applause)) as a viral signal + optional Voice Isolator.
ELEVENLABS_API_KEY=
# ELEVENLABS_MODEL=scribe_v1        # scribe_v2 = newer, supports NO_VERBATIM
# ELEVENLABS_LANGUAGE=              # blank/multi → auto-detect
# ELEVENLABS_DIARIZE=true
# ELEVENLABS_NUM_SPEAKERS=          # optional int hint
# ELEVENLABS_TAG_AUDIO_EVENTS=true
# ELEVENLABS_NO_VERBATIM=false      # v2 only: strip fillers at the source
# ELEVENLABS_AUDIO_ISOLATION=false  # pre-ASR noise strip (helps all providers)
# ELEVENLABS_HTTP_TIMEOUT=600
# ELEVENLABS_MAX_RETRIES=3
# ELEVENLABS_MAX_FILE_MB=2900

# Whisper fallback speaker diarization (via pyannote.audio).
# Requires ENABLE_WHISPER_DIARIZE=1 at docker build time AND HF_TOKEN
# below set to a token that has accepted pyannote/speaker-diarization-3.1.
# WHISPER_DIARIZE=true

# Whisper model (used when TRANSCRIPTION_PROVIDER=whisper, or as
# fallback when Deepgram fails). Auto-detected based on hardware.
# Options: tiny, base, small, medium, large-v3
# Auto-selection:
#   GPU >=6GB VRAM → large-v3 (best quality)
#   GPU >=3GB VRAM → medium
#   GPU <3GB VRAM  → small
#   CPU >=16GB RAM → medium
#   CPU >=8GB RAM  → small
#   CPU <8GB RAM   → base
# WHISPER_MODEL=large-v3

# Hugging Face token (optional — speeds up Whisper model downloads)
# Get yours at https://huggingface.co/settings/tokens
HF_TOKEN=

# ── YouTube download ──────────────────────────────────────────
# Inline cookies fallback (recommended: upload via dashboard instead)
YOUTUBE_COOKIES=

# yt-dlp hardening (all optional).
# NOCHECKCERT=1 disables SSL verification — only use in sandboxed
# environments with broken cert chains. Default: SSL on.
# YTDLP_NOCHECKCERT=
# Threshold in bytes/sec below which yt-dlp re-fetches a throttled
# segment (default: 102400 = 100 KB/s, catches the YouTube 16-23h
# evening throttling window).
# YTDLP_THROTTLED_RATE=102400

# ── Zernio social publishing (optional) ───────────────────────
# Only needed if you plan to publish clips directly to TikTok /
# Instagram / YouTube from the dashboard. Configure via the
# Settings tab — the API key is stored in data/config.json, not
# here, so it never lands in your shell history.
# ZERNIO_BASE_URL=https://zernio.com/api/v1
# ZERNIO_DEFAULT_TZ=Europe/Rome
# ZERNIO_HTTP_TIMEOUT=60
# ZERNIO_UPLOAD_TIMEOUT=600
# ZERNIO_MIN_GAP_SECONDS=5400      # SmartScheduler anti-collision gap

# ── Server ────────────────────────────────────────────────────
# Maximum concurrent processing jobs (default: 5)
MAX_CONCURRENT_JOBS=5

# Comma-separated list of allowed CORS origins
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:5175

# Honour X-Forwarded-For / X-Real-IP for client identity (rate limiting +
# private-network trust). OFF by default: when the app is reachable directly,
# those headers are attacker-controlled. Set to 1 ONLY behind exactly one
# reverse proxy. The backend reads the LAST X-Forwarded-For hop — the address
# the proxy itself wrote — so it is safe whether your proxy APPENDS to the
# header (nginx's $proxy_add_x_forwarded_for, as shipped in
# dashboard/nginx.conf) or overwrites it ($remote_addr). A chain of two or
# more proxies is NOT supported (the last hop would be the inner proxy).
# TRUST_PROXY=0

# GPU runtime (default: cpu — works on all platforms)
#   cpu    — CPU only (x86_64, ARM64, Apple Silicon)
#   nvidia — NVIDIA GPU with CUDA (x86_64 only)
#
# NVIDIA users: `docker compose -f docker-compose.yml -f docker-compose.gpu.yml up --build`
GPU_RUNTIME=cpu

# Enable speaker diarization on the Whisper fallback path. Bakes
# pyannote.audio + deps into the image (~500 MB). Off by default
# because the Deepgram path already has free built-in diarization.
# Build with: docker compose build --build-arg ENABLE_WHISPER_DIARIZE=1
# ENABLE_WHISPER_DIARIZE=0

# ── Reframe / camera comfort ──────────────────────────────────
# Comfort mode (anti-nausea) is ON by default. It biases the virtual camera
# toward a locked crop + fixed per-scene zoom — the research-backed fix for the
# seasickness caused by continuous face tracking. Costs a second decode pass.
# Set to 0 to revert to the original single-pass streaming tracker.
# REFRAME_COMFORT=1
# REFRAME_STATIONARY_THRESH=0.30   # scene-lock threshold (comfort default 0.30)
# REFRAME_ZOOM_LOCK=1              # one zoom per scene (comfort default on)
# REFRAME_SNAP_CENTER=0.10
# REFRAME_STATIC_AUTO=1            # within a scene the camera never moves (default on)

# Streaming-tracker tuning (apply when REFRAME_COMFORT=0 or in TRACK scenes)
# REFRAME_DEADZONE_X=0.05          # dead-band before the camera reacts (fraction)
# REFRAME_DEADZONE_Y=0.08
# REFRAME_LOST_HOLD=90             # frames to hold a lost subject before drifting
# REFRAME_LOST_DRIFT=0.05          # per-frame ease back toward center
# REFRAME_MOTION_WIDE_THRESH=0.12  # single-subject travel that demotes TRACK→WIDE
# REFRAME_MAX_STEP_PX=0            # hard per-frame pan cap in px (0 = off)

# Optional smoothers (A/B tuning — default is the two-speed EMA)
# REFRAME_SMOOTHER=                # euro | spring | (blank = default EMA)
# REFRAME_EURO_MINCUTOFF=0.014     # 1€ smoothness floor (lower = smoother/laggier)
# REFRAME_EURO_BETA=0.0008         # 1€ speed responsiveness (higher = snappier)
# REFRAME_SPRING_RESPONSE=0.18     # damped-spring accel
# REFRAME_SPRING_DAMPING=0.82      # damped-spring decay

# Global 2-pass trajectory smoothing. NOTE: REFRAME_GLOBAL_METHOD (kalman/l2)
# only takes effect when REFRAME_STATIC_AUTO=0 — with the default static-auto
# policy each scene collapses to a single locked crop and the trajectory
# smoother never runs. Docs-level caveat, not a bug.
# REFRAME_GLOBAL_SMOOTH=0          # opt-in track-then-render 2-pass
# REFRAME_GLOBAL_METHOD=savgol     # savgol | kalman | l2 (requires STATIC_AUTO=0)

# Faceless-scene (GENERAL) crop upgrades — both opt-in, letterbox is default
# REFRAME_SALIENT_GENERAL=0        # 1 = Sobel-saliency crop instead of letterbox
# REFRAME_OBJECT_WEIGHTS=          # 1/true = curated COCO weights, or dog:3,car:2,…
# REFRAME_FRAMESHIFT_WEIGHTS=      # subject-mode weights: face:1,person:0.8,default:0.5,…

# Subject (FrameShift) mode smoothing — ON by default. The crop follows one
# per-scene smoothed trajectory (with short detection dropouts bridged) instead
# of re-centering independently every frame, which strobed on detection flicker.
# Set REFRAME_SUBJECT_SMOOTH=0 to restore the legacy per-frame crop exactly.
# REFRAME_SUBJECT_SMOOTH=1
# REFRAME_SUBJECT_HOLD=45          # frames to hold the last subject position across a dropout (~1.5s @30fps)

# Framing / detection quality
# REFRAME_HEADROOM_Y=0.42          # eye-line fraction of crop height (rule of thirds); 0.5 = legacy dead-center
# REFRAME_FACE_CONF=0.5            # face-detection confidence floor (0.5 = model minimum, no extra filtering)
# REFRAME_YOLO_MODEL=yolov8n.pt    # allowlisted: yolov8n/s/m.pt or yolo11n/s.pt — bigger = better detection,
#                                  # 2-3x slower on CPU and a ~20-50MB lazy download on first use
